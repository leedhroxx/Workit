# Django
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=

# 데이터베이스 (MySQL) — DB_HOST를 비워두면 로컬 SQLite로 폴백
DB_HOST=
DB_NAME=workit
DB_USER=admin
DB_PASSWORD=
DB_PORT=3306

# Qdrant (법령 RAG 벡터 검색)
QDRANT_HOST=localhost
QDRANT_PORT=6333

# Celery / Redis
CELERY_BROKER_URL=redis://localhost:6379/0

# 파일 저장소 — USE_S3=True면 S3, 아니면 로컬 디스크
USE_S3=False
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=ap-northeast-2

# 이메일 발송 (알림용)
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# 계정 정책
ACCOUNTS_INITIAL_PASSWORD=

# 사이트 URL (이메일 알림 링크 등에 사용)
SITE_URL=http://localhost:8000

# RunPod 원격 GPU 추론 서버 — 비어있으면 로컬 CPU로 직접 모델을 로드해 폴백
EMBED_SERVER_URL=
LLM_SERVER_URL=
LLM_API_KEY=
